#!/bin/bash

OUTPUT="full_project.txt"

# Kimeneti fájl ürítése
> "$OUTPUT"

echo "Fájlok összegyűjtése a $OUTPUT fájlba..."

# A find parancs magyarázata:
# 1. 'bin lib initcpio data docbook' -> Csak ezekben a releváns mappákban keresünk
# 2. -name "Makefile" ... -> Illetve a gyökérben lévő konkrét fájlokat is hozzávesszük
# 3. A sort biztosítja, hogy a fájlok mindig azonos sorrendben kerüljenek a szövegbe (fontos LLM kontextusnál)

find bin lib initcpio data docbook -type f \
    -o -name "Makefile" \
    -o -name "README.md" \
    | grep -v "packed-refs" \
    | sort \
    | while read -r file; do
        # Kihagyjuk magát a kimeneti fájlt, ha véletlenül belekerülne
        if [[ "$file" == "$OUTPUT" ]]; then continue; fi

        # Fejléc írása
        echo -e "\n=========================================" >> "$OUTPUT"
        echo -e "FILE: $file" >> "$OUTPUT"
        echo -e "=========================================\n" >> "$OUTPUT"

        # Tartalom másolása
        cat "$file" >> "$OUTPUT"
    done

echo "Kész."
